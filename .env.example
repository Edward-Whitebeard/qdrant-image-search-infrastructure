# Local Docker deployment -------------------------------------------------
# Keep 127.0.0.1 for this student project. Do not set 0.0.0.0 unless you
# intentionally want to expose Qdrant to other devices on the network.
QDRANT_BIND_ADDRESS=127.0.0.1
QDRANT_HTTP_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_LOG_LEVEL=INFO

# Shared application contract --------------------------------------------
# For local Docker, leave QDRANT_API_KEY empty.
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=stl10_clip_images
QDRANT_VECTOR_SIZE=512
QDRANT_DISTANCE=Cosine

# Qdrant Cloud alternative ------------------------------------------------
# Do not use the values above with Cloud. Instead set, for example:
# QDRANT_URL=https://<your-cluster-url>
# QDRANT_API_KEY=<database-api-key>
